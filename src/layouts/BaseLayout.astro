---
import Meta from '@components/Meta.astro';
import SkipToContent from '@components/SkipToContent.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'mskosman.com',
  description = 'Homeschool, tutoring, and extracurricular lesson plans aligned to Virginia DOE K–12 Standards of Learning',
  canonical,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <Meta title={title} description={description} canonical={canonical} />
  </head>
  <body class="min-h-screen">
    <SkipToContent />
    <slot />
    <script>
      // Theme switcher with system preference support
      function getSystemTheme() {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }

      function applyTheme(themeSetting: string) {
        let actualTheme: string;
        
        if (themeSetting === 'system') {
          actualTheme = getSystemTheme();
        } else {
          actualTheme = themeSetting;
        }
        
        document.documentElement.setAttribute('data-theme', actualTheme);
      }

      // Initialize theme on page load
      const savedTheme = localStorage.getItem('theme') || 'system';
      applyTheme(savedTheme);

      // Listen for theme changes from the switcher
      window.addEventListener('theme-change', ((e: CustomEvent) => {
        const newTheme = e.detail.theme;
        localStorage.setItem('theme', newTheme);
        applyTheme(newTheme);
      }) as EventListener);

      // Listen for system theme changes when theme is set to 'system'
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        const currentTheme = localStorage.getItem('theme') || 'system';
        if (currentTheme === 'system') {
          applyTheme('system');
        }
      });
    </script>
  </body>
</html>
