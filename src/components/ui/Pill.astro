---
/**
 * SOL Pill Component
 * Renders subject (solid) or grade (outline) pills with locked color tokens
 */

interface Props {
  type: 'subject' | 'grade';
  hue: number;
  label: string;
  href?: string;
}

const { type, hue, label, href } = Astro.props;

---

{href ? (
  <a 
    href={href} 
    class={`pill pill--${type}`}
    data-hue={hue}
  >
    {label}
  </a>
) : (
  <span 
    class={`pill pill--${type}`}
    data-hue={hue}
  >
    {label}
  </span>
)}

<style>
  .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 9999px;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
    white-space: nowrap;
    box-sizing: border-box;
    line-height: 1;
  }

  /* Solid Pills (Subjects) - Increased by 2px total height */
  .pill--subject {
    border: none;
    padding: calc(0.375rem + 1px) 0.75rem;
  }

  /* Outline Pills (Grades) - Border reduces internal space, increased by 2px total height */
  .pill--outline,
  .pill--grade {
    background: transparent;
    border-width: 3px;
    border-style: solid;
    /* Reduce padding by 2x stroke (6px) then add back 1px for height parity with duration pills */
    padding: calc(0.375rem - 2px) 0.75rem;
  }

  /* Hover Behavior */
  .pill:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
  }

  :root[data-theme='dark'] .pill:hover {
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
  }

