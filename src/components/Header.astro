---
import ThemeSwitcher from './ThemeSwitcher.astro';

const currentPath = Astro.url.pathname;
---

<header class="border-b border-border bg-background sticky top-0 z-50">
  <div class="container mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <!-- Left: Logo -->
      <a href="/" class="text-2xl font-bold text-primary-600 dark:text-primary-400">
        mskosman.com
      </a>
      
      <!-- Center: Navigation -->
      <nav class="flex items-center gap-6">
        <a
          href="/lesson-plans"
          class:list={[
            'text-sm font-medium transition-colors hover:text-primary-600',
            currentPath.startsWith('/lesson-plans') ? 'text-primary-600' : 'text-gray-600 dark:text-gray-300'
          ]}
        >
          Lesson Plans
        </a>
        <a
          href="/standards"
          class:list={[
            'text-sm font-medium transition-colors hover:text-primary-600',
            currentPath.startsWith('/standards') ? 'text-primary-600' : 'text-gray-600 dark:text-gray-300'
          ]}
        >
          Standards
        </a>
        <a
          href="/about"
          class:list={[
            'text-sm font-medium transition-colors hover:text-primary-600',
            currentPath === '/about' ? 'text-primary-600' : 'text-gray-600 dark:text-gray-300'
          ]}
        >
          About
        </a>
        <a
          href="/contact"
          class:list={[
            'text-sm font-medium transition-colors hover:text-primary-600',
            currentPath === '/contact' ? 'text-primary-600' : 'text-gray-600 dark:text-gray-300'
          ]}
        >
          Contact
        </a>
      </nav>
      
      <!-- Right: Theme Switcher -->
      <div class="flex items-center gap-4">
        <ThemeSwitcher />
      </div>
    </div>
  </div>
</header>
