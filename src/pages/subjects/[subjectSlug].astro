---
import MainLayout from '@layouts/MainLayout.astro';
import LessonCard from '@components/LessonCard.astro';
import { getCollection } from 'astro:content';
import { SUBJECTS, SUBJECT_SLUGS, type Subject } from '@lib/constants';

export async function getStaticPaths() {
  const allLessons = await getCollection('lessons');
  
  return SUBJECTS.map((subject) => ({
    params: { subjectSlug: SUBJECT_SLUGS[subject] },
    props: {
      subject,
      lessons: allLessons
        .filter((lesson) => lesson.data.subject === subject)
        .sort((a, b) => {
          // Convert grades to numbers for proper sorting (k=0, 1-12)
          const gradeA = a.data.grade === 'k' ? 0 : parseInt(a.data.grade);
          const gradeB = b.data.grade === 'k' ? 0 : parseInt(b.data.grade);
          return gradeA - gradeB;
        }),
    },
  }));
}

const { subject, lessons } = Astro.props;

// Generate canonical URL
const subjectSlug = SUBJECT_SLUGS[subject as Subject];
const canonicalUrl = `https://mskosman.com/subjects/${subjectSlug}`;
---

<MainLayout
  title={`${subject} Lesson Plans | mskosman.com`}
  description={`Explore ${lessons.length} ${subject} lesson plans aligned to Virginia SOL standards`}
  canonical={canonicalUrl}
>
  <div class="max-w-6xl mx-auto">
    <div class="mb-8">
      <a
        href="/subjects"
        class="text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 mb-4 inline-block"
      >
        ← Back to Subjects
      </a>
      <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-2">
        {subject}
      </h1>
      <p class="text-gray-600 dark:text-gray-300">
        {lessons.length} lesson{lessons.length !== 1 ? 's' : ''} available
      </p>
    </div>

    {lessons.length > 0 ? (
      <LessonCard lessons={lessons} hoverBy="grade" />
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-500 dark:text-gray-400">
          No lessons available yet for this subject.
        </p>
      </div>
    )}
  </div>
</MainLayout>
